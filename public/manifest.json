{
  "manifest_version": 3,
  "name": "My React Todo List",
  "version": "1.0",
  "description": "A simple todo list extension built with React.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Open Todo List",
     "default_icon" : "todo.png"
  }
}